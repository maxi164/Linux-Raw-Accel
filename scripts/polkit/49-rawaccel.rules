/* RawAccel Linux — polkit rules
 *
 * Users in the 'input' group can start rawaccel-daemon without a password.
 * This rule runs before the default (50-default.rules) because of the lower
 * priority number (49 < 50).
 *
 * Performance note: evaluated only at daemon start, not in the hot path.
 */
polkit.addRule(function(action, subject) {
    if (action.id === "org.rawaccel.daemon.start" &&
        subject.isInGroup("input") &&
        subject.local &&
        subject.active) {
        return polkit.Result.YES;
    }

    /* Allow GUI/CLI users in the input group to manage only rawaccel.service
     * through systemd.  This is the path used when the daemon is installed as
     * a system service; it avoids pkexec(systemctl) password prompts without
     * granting broad service-management rights.
     */
    if (action.id === "org.freedesktop.systemd1.manage-units" &&
        action.lookup("unit") === "rawaccel.service" &&
        ["start", "stop", "restart", "reload"].indexOf(action.lookup("verb")) >= 0 &&
        subject.isInGroup("input") &&
        subject.local &&
        subject.active) {
        return polkit.Result.YES;
    }
});
